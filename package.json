{
	"name": "com.mrlectus.cfhono",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"db:push": "drizzle-kit push",
		"db:local": "wrangler d1 migrations apply cfhono --local",
		"db:migrate": "drizzle-kit migrate",
		"auth:generate": "pnpm dlx @better-auth/cli generate --config ./src/lib/auth.ts --output ./src/repo/schema/auth.schema.ts",
		"better-auth-gen-schema": "pnpm dlx @better-auth/cli@latest generate --config ./better-auth.config.ts --output ./src/repo/schema/auth.schema.ts",
		"db:generate": "drizzle-kit generate",
		"lint": "biome check",
		"format": "biome format",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"@hono/standard-validator": "^0.2.2",
		"@scalar/hono-api-reference": "^0.11.4",
		"better-auth": "^1.6.19",
		"date-fns": "^4.4.0",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"effect": "^3.21.4",
		"hono": "^4.12.26",
		"hono-openapi": "^1.3.0",
		"hono-pino": "^0.10.3",
		"node-addon-api": "^8.8.0",
		"node-gyp": "^13.0.0",
		"pino": "^10.3.1",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.0",
		"@cloudflare/workers-types": "^4.20260619.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^26.0.0",
		"drizzle-kit": "^0.31.10",
		"wrangler": "^4.102.0"
	}
}
