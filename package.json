{
	"name": "com.mrlectus.cfhono",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"deploy": "wrangler deploy --minify",
		"db:push": "drizzle-kit push",
		"db:local": "wrangler d1 migrations apply cfhono --local",
		"db:migrate": "drizzle-kit migrate",
		"auth:generate": "pnpm dlx @better-auth/cli generate --config ./src/lib/auth.ts --output ./src/repo/schema/auth.schema.ts",
		"better-auth-gen-schema": "pnpm dlx @better-auth/cli@latest generate --config ./better-auth.config.ts --output ./src/repo/schema/auth.schema.ts",
		"db:generate": "drizzle-kit generate",
		"lint": "biome check",
		"format": "biome format",
		"cf-typegen": "wrangler types --env-interface CloudflareBindings"
	},
	"dependencies": {
		"@hono/standard-validator": "^0.2.2",
		"@scalar/hono-api-reference": "^0.10.3",
		"better-auth": "^1.5.5",
		"date-fns": "^4.1.0",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"effect": "^3.19.19",
		"hono": "^4.12.7",
		"hono-openapi": "^1.3.0",
		"hono-pino": "^0.10.3",
		"pino": "^10.3.1",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@cloudflare/workers-types": "^4.20260313.1",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.5.0",
		"drizzle-kit": "^0.31.9",
		"wrangler": "^4.72.0"
	}
}
